{
    "name": "tapscore",
    "private": true,
    "type": "module",
    "scripts": {
        "dev:server": "PORT=3030 bun --watch server/main.ts",
        "build": "vite build",
        "check:client": "tsgo --noEmit",
        "check:server": "tsgo -p tsconfig.server.json --noEmit",
        "check:test": "tsgo -p tsconfig.test.json --noEmit",
        "test": "bun test --path-ignore-patterns='vendor/**'",
        "test:server": "bun test --path-ignore-patterns='vendor/**' server/",
        "test:client": "bun test tests/ src/",
        "test:scripts": "bun test scripts/",
        "test:framework": "bun test --preload ./scripts/framework-test-preload.ts vendor/basics-core/",
        "test:affected": "bun vendor/basics-core/affected-tests.ts",
        "generate": "bun vendor/basics-core/generate-api.ts",
        "reset:dev": "rm -rf data/",
        "render:round": "bun scripts/render-round.ts",
        "render:all": "bun scripts/render-all.ts",
        "render:formats": "bun scripts/render-formats.ts",
        "seed": "bun scripts/seed.ts",
        "seed:prod": "bun scripts/seed-prod.ts",
        "seed:list": "bun scripts/seed.ts list",
        "seed:formats": "bun scripts/seed-formats.ts",
        "check:format-fixtures": "bun scripts/check-format-fixtures.ts",
        "db:migrate": "bun ./scripts/migrate.ts",
        "db:health": "bun ./scripts/health.ts",
        "vendor:basics": "bun ./scripts/vendor-basics.ts"
    },
    "dependencies": {
        "@basics/core": "file:./vendor/basics-core",
        "@sinclair/typebox": "0.34.48",
        "hono": "4.11.9",
        "kysely": "0.27.6",
        "kysely-bun-sqlite": "0.3.2"
    },
    "devDependencies": {
        "@types/bun": "^1",
        "@typescript/native-preview": "^7.0.0-dev.20260211.1",
        "typescript": "^5.9.3",
        "vite": "^7.3.1"
    }
}
